--         LOOP PRINCIPAL
-- ══════════════════════════════════

RunService.Heartbeat:Connect(function()
    if not Settings.AutoHunt then
        StatusLabel.Text = "Estado: Pausado"
        TargetLabel.Text = "Objetivo: Ninguno"
        ZoneLabel.Text   = "Zona: --"
        return
    end

    local bestTarget, highestBounty = nil, Settings.MinBounty

    for _, player in pairs(Players:GetPlayers()) do
        if IsValidTarget(player) then
            local ls = player:FindFirstChild("leaderstats")
            local b  = ls and (ls:FindFirstChild("Bounty") or ls:FindFirstChild("Festas"))
            if b and b.Value > highestBounty then
                highestBounty = b.Value
                bestTarget = player
            end
        end
    end

    if bestTarget then
        TargetLabel.Text = "Objetivo: " .. bestTarget.Name
        StatusLabel.Text = "Estado: 🏃 Persiguiendo"
        ZoneLabel.Text   = "💰 Bounty: " .. highestBounty
        TweenToTarget(bestTarget)
    else
        StatusLabel.Text = "Estado: 🔍 Buscando..."
        TargetLabel.Text = "Objetivo: Ninguno"
        ZoneLabel.Text   = "Sin objetivos válidos"
        if currentTween then currentTween:Cancel() currentTween = nil end
    end
end)

