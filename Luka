local function CreateESP(player)
    if player == LocalPlayer then return end

    player.CharacterAdded:Connect(function(char)
        task.wait(1)
        local root = char:WaitForChild("HumanoidRootPart", 5)
        if not root then return end

        if root:FindFirstChild("BountyESP") then
            root.BountyESP:Destroy()
        end

        local billboard = Instance.new("BillboardGui")
        billboard.Name = "BountyESP"
        billboard.AlwaysOnTop = true
        billboard.Size = UDim2.new(0, 160, 0, 45)
        billboard.StudsOffset = Vector3.new(0, 3.5, 0)
        billboard.Parent = root

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.TextStrokeTransparency = 0
        label.Font = Enum.Font.GothamBold
        label.TextSize = 13
        label.Parent = billboard

        RunService.Heartbeat:Connect(function()
            if not root or not root.Parent then return end
            local ls = player:FindFirstChild("leaderstats")
            local b  = ls and (ls:FindFirstChild("Bounty") or ls:FindFirstChild("Festas"))
            local bv = b and b.Value or 0

            if IsInSafeZone(player) then
                label.TextColor3 = Color3.fromRGB(100, 200, 255)
                label.Text = "🔵 " .. player.Name .. "\n[ZONA SEGURA]"
            elseif IsPVPDisabled(player) then
                label.TextColor3 = Color3.fromRGB(180, 180, 180)
                label.Text = "⚪ " .. player.Name .. "\n[PVP OFF]"
            elseif bv >= Settings.MinBounty then
                label.TextColor3 = Color3.fromRGB(255, 60, 60)
                label.Text = "🏴 " .. player.Name .. "\n💰 " .. bv
            else
                label.TextColor3 = Color3.fromRGB(200, 200, 200)
                label.Text = player.Name .. "\n💰 " .. bv
            end
        end)
    end)

    if player.Character then
        player.CharacterAdded:Fire(player.Character)
    end
end

for _, p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

