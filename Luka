            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

-- ══════════════════════════════════
--           KILL COUNTER
-- ══════════════════════════════════

local function WatchKills()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if not ls then
        LocalPlayer.ChildAdded:Connect(function(child)
            if child.Name == "leaderstats" then WatchKills() end
        end)
        return
    end

    local kills = ls:FindFirstChild("Kills")
               or ls:FindFirstChild("Bounty_Kills")
               or ls:FindFirstChild("PlayerKills")

    if kills then
        local lastValue = kills.Value
        kills.Changed:Connect(function(newValue)
            if newValue > lastValue then
                KillCount += (newValue - lastValue)
                KillLabel.Text = "💀 Kills: " .. KillCount
                StatusLabel.Text = "🎯 ¡Kill! Total: " .. KillCount
                task.delay(2, function()
                    if Settings.AutoHunt then
                        StatusLabel.Text = "Estado: 🏃 Persiguiendo"
                    end
                end)
            end
            lastValue = newValue
        end)
    else
        -- Fallback por proximidad al respawn
        Players.PlayerAdded:Connect(function(player)
            if player == LocalPlayer then return end
            player.CharacterAdded:Connect(function()
                task.wait(0.5)
                local myRoot = LocalPlayer.Character
                    and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                local theirRoot = player.Character
                    and player.Character:FindFirstChild("HumanoidRootPart")
                if myRoot and theirRoot then
                    if (theirRoot.Position - myRoot.Position).Magnitude <= 50 then
                        KillCount += 1
                        KillLabel.Text = "💀 Kills: " .. KillCount
                    end
                end
            end)
        end)
    end
end

WatchKills()

