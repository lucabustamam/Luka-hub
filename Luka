-- ══════════════════════════════════
--       DETECCIÓN ZONA SEGURA
-- ══════════════════════════════════

local function IsInSafeZone(player)
    if not Settings.SafeZoneCheck then return false end
    local char = player.Character
    if not char then return false end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return false end

    local safeZones = workspace:FindFirstChild("SafeZones")
                   or workspace:FindFirstChild("SafeArea")
                   or workspace:FindFirstChild("Zones")

    if safeZones then
        for _, zone in pairs(safeZones:GetChildren()) do
            local zonePart = zone:IsA("Model") and zone.PrimaryPart or zone
            if zonePart and zonePart:IsA("BasePart") then
                local rel  = zonePart.CFrame:ToObjectSpace(CFrame.new(root.Position))
                local size = zonePart.Size / 2
                if math.abs(rel.X) < size.X and
                   math.abs(rel.Y) < size.Y + 10 and
                   math.abs(rel.Z) < size.Z then
                    return true
                end
            end
        end
    end

    local safeZoneNames = {"Starter","Town","SafeZone","Spawn","Hub","Port"}
    for _, name in pairs(safeZoneNames) do
        local found = workspace:FindFirstChild(name, true)
        if found and found:IsA("BasePart") then
            if (found.Position - root.Position).Magnitude < 60 then
                return true
            end
        end
    end

    return false
end

-- ══════════════════════════════════
--        DETECCIÓN PVP OFF
-- ══════════════════════════════════

local function IsPVPDisabled(player)
    if not Settings.PVPCheck then return false end
    local char = player.Character
    if not char then return false end

    if char:FindFirstChild("PVPOff")
    or char:FindFirstChild("NoPVP")
    or char:FindFirstChild("SafeMode") then
        return true
    end

    local pvpValue = player:FindFirstChild("PVP")
    if pvpValue and pvpValue:IsA("BoolValue") and not pvpValue.Value then
        return true
    end

    return false
end

-- ══════════════════════════════════
--        VALIDAR OBJETIVO
-- ══════════════════════════════════

local function IsValidTarget(player)
    if player == LocalPlayer then return false end
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if IsInSafeZone(player) then return false end
    if IsPVPDisabled(player) then return false end

    local ls = player:FindFirstChild("leaderstats")
    if ls then
        local b = ls:FindFirstChild("Bounty") or ls:FindFirstChild("Festas")
        if b and b.Value >= Settings.MinBounty then return true end
    end

    return false
end

-- ══════════════════════════════════
--        TWEEN MOVEMENT
-- ══════════════════════════════════

local function TweenToTarget(target)
    if not target or not target.Character then return end
    local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
    local myChar     = LocalPlayer.Character
    local myRoot     = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not targetRoot or not myRoot then return end

    local dist = (targetRoot.Position - myRoot.Position).Magnitude
    if dist <= Settings.AttackRange then return end

    if currentTween then
        currentTween:Cancel()
        currentTween = nil
    end

    local goalCFrame = targetRoot.CFrame * CFrame.new(0, 0, -Settings.AttackRange)
    local tweenTime  = dist / Settings.TweenSpeed

    currentTween = TweenService:Create(
        myRoot,
        TweenInfo.new(tweenTime, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
        {CFrame = goalCFrame}
    )
    currentTween:Play()
end

